{
  "expo": {
    "name": "LSO App",
    "slug": "lso-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "lsoapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "description": "Aplikacja dla Liturgicznej Służby Ołtarza — grafik służb, weryfikacja obecności i punktacja ministrantów.",
    "privacyPolicyUrl": "https://lsoapp.pl/privacy",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D1F6B"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "pl.lsoapp.app",
      "buildNumber": "1"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0D1F6B"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.VIBRATE",
        "android.permission.RECEIVE_BOOT_COMPLETED"
      ],
      "package": "pl.lsoapp.app",
      "versionCode": 1
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Aplikacja LSO potrzebuje dostępu do kamery do skanowania kodów QR."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Aplikacja LSO potrzebuje dostępu do lokalizacji do weryfikacji obecności."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#534AB7",
          "sounds": []
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "948ef4cf-804f-4539-aea5-234b68ce2087"
      }
    },
    "owner": "majlosz"
  }
}
